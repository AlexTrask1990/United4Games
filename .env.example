# -----------------------------------------------------------------------------
# Local development: copy to .env.local and adjust values.
# Vercel: Project → Settings → Environment Variables (see notes below).
# -----------------------------------------------------------------------------

# NODE_ENV is set automatically by Next.js / Vercel (development | production).
# Do NOT add NODE_ENV to Vercel — it can break builds and runtime behavior.

# Site URL for SEO, sitemap, canonical, Open Graph.
# Local (.env.local):
BASE_URL=http://localhost:3000
# Vercel Production (when domain is connected):
# BASE_URL=https://united4games.com
# Vercel Production / Preview (before custom domain):
# BASE_URL=https://your-project.vercel.app

TWITTER_HANDLE=

# app-ads.txt admin (/admin/app-ads)
APP_ADS_ADMIN_SECRET=

# Hook Wars store links (Our Games section)
NEXT_PUBLIC_HOOK_WARS_ANDROID_URL=
NEXT_PUBLIC_HOOK_WARS_IOS_URL=

# Optional social profile URLs (footer icons stay disabled until set)
NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NEXT_PUBLIC_SOCIAL_TWITTER_URL=
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=

# Contact form — single mailbox (SMTP auth + default delivery)
SUPPORT_EMAIL=
EMAIL_PASSWORD=

# SMTP provider: microsoft365 (default) or godaddy
SMTP_PROVIDER=microsoft365
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false

# Optional delivery overrides. If empty, both U4G and U4D go to SUPPORT_EMAIL.
SUPPORT_EMAIL_U4G=
SUPPORT_EMAIL_U4D=

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# reCAPTCHA is automatically disabled when NODE_ENV=development (npm run dev).

# -----------------------------------------------------------------------------
# Vercel environment scopes:
# - Production  → united4games.com (or *.vercel.app until domain is ready)
# - Preview     → PR deployments (same BASE_URL as prod is OK for now)
# - Development → only `vercel dev` locally, NOT deployed preview URLs
# -----------------------------------------------------------------------------
